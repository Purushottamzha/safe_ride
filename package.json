{
  "name": "saferide-nepal",
  "version": "1.0.0",
  "private": true,
  "description": "SafeRide Nepal - School Bus Management System",
  "scripts": {
    "dev": "docker compose up --build",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:admin": "cd admin-web && npm run dev",
    "dev:parent": "cd parent-web && npm run dev",
    "build": "cd backend && npm run build",
    "lint": "cd backend && npm run lint",
    "test": "cd backend && npm run test",
    "test:e2e": "cd backend && npm run test:e2e",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:seed": "cd backend && npx prisma db seed",
    "db:studio": "cd backend && npx prisma studio",
    "clean": "rm -rf backend/dist admin-web/dist parent-web/dist"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
