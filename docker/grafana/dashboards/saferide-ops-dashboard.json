{
  "title": "SafeRide Operations Dashboard",
  "uid": "saferide-ops",
  "version": 1,
  "tags": ["saferide"],
  "timezone": "browser",
  "schemaVersion": 36,
  "panels": [
    {
      "title": "Online Buses",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "saferide_active_buses", "legendFormat": "Active Buses"}],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed"},
          "thresholds": {"steps": [{"value": null, "color": "green"}]},
          "unit": "none"
        }
      }
    },
    {
      "title": "API Latency (p95)",
      "type": "stat",
      "gridPos": {"x": 3, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[5m])) by (le))", "legendFormat": "p95"}],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"value": null, "color": "green"}, {"value": 200, "color": "yellow"}, {"value": 1000, "color": "red"}]},
          "unit": "ms"
        }
      }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "rate(http_errors_total[5m])", "legendFormat": "Errors/s"}],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"value": null, "color": "green"}, {"value": 0.1, "color": "red"}]}
        }
      }
    },
    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": {"x": 9, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "rate(http_requests_total[5m])", "legendFormat": "Requests/s"}],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed"},
          "unit": "reqps"
        }
      }
    },
    {
      "title": "MQTT Status",
      "type": "stat",
      "gridPos": {"x": 0, "y": 3, "w": 3, "h": 3},
      "targets": [{"expr": "saferide_mqtt_connected", "legendFormat": "MQTT"}],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 1, "color": "green"}]},
          "mappings": [{"options": {"0": {"text": "Disconnected", "color": "red"}, "1": {"text": "Connected", "color": "green"}}, "type": "value"}]
        }
      }
    },
    {
      "title": "Scanner Battery",
      "type": "gauge",
      "gridPos": {"x": 3, "y": 3, "w": 9, "h": 3},
      "targets": [{"expr": "saferide_device_battery_percent", "legendFormat": "{{bus_id}}"}],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"value": null, "color": "green"}, {"value": 20, "color": "red"}]},
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "GPS Accuracy",
      "type": "table",
      "gridPos": {"x": 0, "y": 6, "w": 6, "h": 5},
      "targets": [{"expr": "saferide_device_gps_accuracy_meters", "legendFormat": "{{bus_id}}"}],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"value": null, "color": "green"}, {"value": 10, "color": "yellow"}, {"value": 50, "color": "red"}]},
          "unit": "m"
        }
      }
    },
    {
      "title": "Heartbeat Age",
      "type": "table",
      "gridPos": {"x": 6, "y": 6, "w": 6, "h": 5},
      "targets": [{"expr": "saferide_device_heartbeat_seconds", "legendFormat": "{{bus_id}}"}],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"value": null, "color": "green"}, {"value": 60, "color": "yellow"}, {"value": 120, "color": "red"}]},
          "unit": "s"
        }
      }
    },
    {
      "title": "API Latency Heatmap",
      "type": "heatmap",
      "gridPos": {"x": 0, "y": 11, "w": 12, "h": 8},
      "targets": [{"expr": "rate(http_request_duration_ms_bucket[1m])", "legendFormat": "{{le}}"}],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 19, "w": 6, "h": 6},
      "targets": [{"expr": "rate(container_cpu_usage_seconds_total[1m])", "legendFormat": "{{name}}"}],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": {"x": 6, "y": 19, "w": 6, "h": 6},
      "targets": [{"expr": "container_memory_usage_bytes", "legendFormat": "{{name}}"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    }
  ]
}
