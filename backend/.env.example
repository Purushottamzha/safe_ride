# Database
DATABASE_URL=postgresql://saferide:saferide_secret_2024@localhost:5432/saferide?schema=public

# Redis
REDIS_URL=redis://default:saferide_redis_2024@localhost:6379

# JWT
JWT_SECRET=saferide_jwt_super_secret_key_2024
JWT_REFRESH_SECRET=saferide_refresh_super_secret_key_2024
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Logging
LOG_LEVEL=debug

# Encryption
ENCRYPTION_KEY=saferide_encryption_key_32_bytes_2024!!!!

# MQTT (Mosquitto broker for device communication)
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=saferide-backend
MQTT_PASSWORD=saferide-mqtt-backend-2024
# MOSQUITTO_PASSWORD is set at the docker-compose level (root .env)
# — used to generate the mosquitto password file for device auth

# OSRM (self-hosted routing engine for ETA calculation)
OSRM_URL=http://localhost:5000
